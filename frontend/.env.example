# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Never put secrets here — this file is safe to commit.

# Backend API base URL.
# - Leave EMPTY for local development (the Vite dev proxy handles /api → localhost:8080).
# - Set to your deployed backend URL for production builds:
#   VITE_API_BASE_URL=https://stadiumsense-backend.onrender.com
VITE_API_BASE_URL=
